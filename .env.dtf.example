# DTF Gang Sheet Builder - Environment Variables

# Background Removal Service
# Get your API key from https://www.remove.bg/api
REMOVEBG_API_KEY=your_removebg_api_key_here

# Gang Sheet Settings
GANG_SHEET_DEFAULT_DPI=300
GANG_SHEET_MAX_FILE_SIZE=10240 # in KB (10MB)
GANG_SHEET_ALLOWED_FORMATS=png,jpg,jpeg,svg

# Image Quality Settings
IMAGE_COMPRESSION_QUALITY=90
IMAGE_MAX_WIDTH=10000
IMAGE_MAX_HEIGHT=10000

# Pricing (in dollars)
GANG_SHEET_PRICE_22X120=165.00
GANG_SHEET_PRICE_22X60=95.00
GANG_SHEET_PRICE_13X19=28.00

# Background Removal Pricing
BG_REMOVAL_PRICE_PER_IMAGE=0.10
BG_REMOVAL_DISCOUNT_50=0.10  # 10% off for 50+ images
BG_REMOVAL_DISCOUNT_100=0.20 # 20% off for 100+ images

# Processing Settings
GANG_SHEET_PROCESSING_TIMEOUT=300 # seconds
GANG_SHEET_QUEUE_CONNECTION=redis # or 'database', 'sync'

# Storage Settings
GANG_SHEET_STORAGE_DISK=public
GANG_SHEET_PREVIEW_PATH=gang-sheets/previews
GANG_SHEET_FINAL_PATH=gang-sheets/final
GANG_SHEET_UPLOADS_PATH=gang-sheets/uploads

# Python Settings (for rembg)
PYTHON_PATH=/usr/bin/python3
PYTHON_SCRIPT_PATH=/path/to/scripts/remove_background.py
